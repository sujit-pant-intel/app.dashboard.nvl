  "fB93xx": [
		{ "FB": "9308", "name": "PreviousSocketBinning", "description": "Previous socket binning (Dice skipped during SDT Good die only testing; e.g., previously bad bin at CMT or SDS)" },
		{ "FB": "9320", "name": "MinDieSkipTray", "description": "Deprecated / no longer used (No longer used)" },
		{ "FB": "9317", "name": "OverTouched", "description": "Touchdown count exceeded limit (Die skipped because it exceeded ThermalAction touchdown limit)" },
		{ "FB": "9399", "name": "Incomplete", "description": "Incomplete die data in ituff (Tester crash or Podituff issue; iLLIAD limit should be 1)" },
		{ "FB": "9305", "name": "VisionTrayReject", "description": "Incoming No-Go tray reject (Vision rejected entire tray on first sort; resort keeps previous bin data)" },
		{ "FB": "9306", "name": "VisionUnitReject", "description": "BVIU No-Go unit reject (Vision rejected die prior to test; may map to 9305 depending on flow)" },
		{ "FB": "9321", "name": "VisionUnitSkip", "description": "IOM unit-level skip (Vision rejected unit during IOM inspection)" },
		{ "FB": "9310", "name": "UnitAlign", "description": "Unit alignment skip (Manual skip due to alignment alarm)" },
		{ "FB": "9311", "name": "UnitAlignZ", "description": "Unit alignment Z difference skip (Manual skip due to Z difference alarm 600147/600152)" },
		{ "FB": "9318", "name": "UnitAlignFail", "description": "Unit alignment auto-skip (Auto skip due to alignment alarm)" },
		{ "FB": "9319", "name": "UnitAlignZFail", "description": "Unit alignment Z difference auto-skip (Auto skip due to Z difference alarm 600147/600152)" },
		{ "FB": "9312", "name": "PnpPutTH", "description": "Pick-and-place put at test head skip (Triggered by vacuum/place alarms 660104, 660107, etc.)" },
		{ "FB": "9313", "name": "PnpTray", "description": "Pick-and-place tray pickup skip (Triggered by tray pick alarms 660100, 660110)" },
		{ "FB": "9314", "name": "AlcComm", "description": "Vision communication failure (Image transfer error alarm 040012)" },
		{ "FB": "9315", "name": "CoarseAlign", "description": "Coarse alignment skip (BVIU coarse alignment alarm 660400)" },
		{ "FB": "9316", "name": "DeviceAlign", "description": "Device alignment skip (Alignment alarm 600118)" },
		{ "FB": "9309", "name": "HCTriggeredSkip", "description": "Handler controller triggered skip (Generic skip not covered by other handler events)" },
		{ "FB": "9307", "name": "TrayMapOverride", "description": "Tray map override skip (Override determines tested die; behavior depends on E/G and inking state)" },
		{ "FB": "9301", "name": "DiePocketEmpty", "description": "Empty die pocket (Presence bin E; verified via SOD or WTT map)" },
		{ "FB": "9302", "name": "BadDie", "description": "Bad die (Presence bin B; only one latest presence value per die)" },
		{ "FB": "9303", "name": "FlaggedForSkip", "description": "Inked or overlay skip (IB200/IB190; overrides presence bin; visible in Blazar SDX_DONTTESTINK)" },
		{ "FB": "9304", "name": "Scrapped", "description": "Scrapped wafer or die (Partial wafer scrapped; may retain prior test bins)" },
		{ "FB": "9300", "name": "Unknown", "description": "Unknown condition (Examples include tray on hold or missing DPC start; iLLIAD limit should be 1)" }
  ],
