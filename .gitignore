# ── Sensitive collateral data — keep folder structure, ignore contents ────────
shared/etest/*
shared/material/*
!shared/etest/.gitkeep
!shared/material/.gitkeep


# ── Large vendored JS — checked in (offline-safe), no secrets ────────────────
# shared/library/plotly-*.js  ← intentionally tracked

# ── Runtime / pipeline outputs ───────────────────────────────────────────────
**/.cache/
**/output*/
**/reports/
**/heatmap/
**/data/raw/
**/data/programs/

# ── Python artifacts ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyd
*.pdb

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.code-workspace

# ── Zip archives (exports/temp) ───────────────────────────────────────────────
*.zip
